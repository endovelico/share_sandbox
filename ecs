### 2. OpenTelemetry Logs

OpenTelemetry is designed around observability and works well if you're already using distributed tracing and metrics.

```json
{
  "timestamp": "2026-07-01T14:32:15.123Z",
  "severityText": "INFO",
  "severityNumber": 9,
  "body": "Customer created successfully",

  "traceId": "4bf92f3577b34da6a3ce929d0e0e4736",
  "spanId": "00f067aa0ba902b7",

  "resource": {
    "service.name": "customer-api",
    "service.version": "2.4.1",
    "deployment.environment": "production"
  },

  "attributes": {
    "event.action": "create_customer",
    "event.outcome": "success",

    "http.request.method": "POST",
    "http.route": "/customers",

    "user.id": "user-123",
    "customer.id": "cust-456",

    "customer.type": "enterprise",
    "source": "web"
  }
}
```

